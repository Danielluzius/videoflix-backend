# Django Admin Superuser (will be automatically created at Docker start)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=adminpassword
DJANGO_SUPERUSER_EMAIL=admin@example.com

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Database (PostgreSQL)
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_LOCATION=redis://redis:6379/1
REDIS_PORT=6379
REDIS_DB=0

# Email (SMTP) - use your own SMTP provider (e.g. Gmail, Outlook, Ionos, etc.)
# Gmail:   EMAIL_HOST=smtp.gmail.com   EMAIL_PORT=587
# Outlook: EMAIL_HOST=smtp.office365.com  EMAIL_PORT=587
# Ionos:   EMAIL_HOST=smtp.ionos.de    EMAIL_PORT=587
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@your-domain.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=your-email@your-domain.com

# Frontend URL (for E-Mail-links)
FRONTEND_URL=http://127.0.0.1:5500
